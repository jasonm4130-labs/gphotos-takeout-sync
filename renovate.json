{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "pinDigests": true,
  "packageRules": [
    {
      "description": "Group the bundled tool bumps (immich-go, supercronic, alpine) into one PR",
      "matchManagers": ["dockerfile"],
      "groupName": "image tooling"
    },
    {
      "description": "Group CI action bumps (build + lint workflows) into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ]
}
