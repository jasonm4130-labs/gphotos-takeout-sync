root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
# Trailing whitespace is significant in Markdown (line breaks), so do not trim.
trim_trailing_whitespace = false

[*.sh]
indent_style = space
indent_size = 4

[Dockerfile]
indent_style = space
indent_size = 4

[Makefile]
# Make requires hard tabs.
indent_style = tab
